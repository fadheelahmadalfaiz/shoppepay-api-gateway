# =========================
# Core ShopeePay credentials
# =========================
SHOPEE_TOKEN=B:your_inner_shopeepay_token_here
API_KEY=your_x_api_key_here
PORT=4000
CORE_PORT=4001

# Telegram alerts (token death + payment paid)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# QRIS static payload (EMVCo string starting with 000201...)
QRIS_STATIC=00020101021126610016ID.CO.SHOPEE.WWW0118...

# =========================
# Auto-check (PG mode)
# =========================
# How often to poll pending payments (ms)
AUTO_CHECK_INTERVAL_MS=10000
# Max polls per payment before marking expired (~20 min at 10s)
AUTO_CHECK_MAX_POLLS=120
# Add random +1..99 to amount to avoid collision (true/false)
UNIQUE_AMOUNT=true
# Persist payment sessions (survives restart)
PAYMENT_STORE_PATH=./data/payments.json
